{
  "name": "@codesoul/parser",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./mock": {
      "types": "./dist/mock.d.ts",
      "import": "./dist/mock.js"
    },
    "./tree-sitter": {
      "types": "./dist/tree-sitter.d.ts",
      "import": "./dist/tree-sitter.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@codesoul/core": "workspace:*",
    "tree-sitter": "0.22.4",
    "tree-sitter-python": "0.23.6",
    "tree-sitter-typescript": "0.23.2"
  }
}
