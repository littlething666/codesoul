      "types": "./dist/mock.d.ts",
      "import": "./dist/mock.js"
    },
    "./package-json": {
      "types": "./dist/package-json.d.ts",
      "import": "./dist/package-json.js"
    },
    "./pyproject": {
      "types": "./dist/pyproject.d.ts",
